# ─── ElevenLabs ───────────────────────────────────────────────────────────────
# Your ElevenLabs API key (https://elevenlabs.io → Profile → API Keys).
ELEVENLABS_API_KEY=

# TTS model used for synthesis. eleven_multilingual_v2 is a good quality default.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ─── Audio output ─────────────────────────────────────────────────────────────
# Format requested PER SEGMENT from the provider (codec_sampleRate_bitrate).
# Best quality (Pro tier+): wav_44100. Safe default for any tier: mp3_44100_128.
SEGMENT_OUTPUT_FORMAT=mp3_44100_128

# Final master export format: "wav" (lossless) or "mp3".
FINAL_FORMAT=wav

# Also export a shareable MP3 alongside the master (true/false).
ALSO_EXPORT_MP3=true

# Silence inserted between speaker turns, in milliseconds.
INTER_TURN_GAP_MS=400

# Directory (relative to the backend working dir) where episodes are written.
OUTPUT_DIR=output

# All segments are resampled to this rate before stitching, so providers with
# different native rates (ElevenLabs up to 44.1kHz, local models 24kHz) mix.
TARGET_SAMPLE_RATE=44100

# ─── Local models (Kokoro, F5) ────────────────────────────────────────────────
# Directory holding F5 reference voices. Defaults to the repo-root assets/ dir.
# Layout: <ASSETS_DIR>/speakers/reference_audio/<name>.wav
#         <ASSETS_DIR>/speakers/reference_text/<name>.txt
# ASSETS_DIR=/absolute/path/to/assets

# Kokoro
KOKORO_SPEED=1.0

# F5
F5_SPEED=1.0
F5_NFE_STEP=32
F5_CFG_STRENGTH=2.0
F5_SWAY_COEF=-1.0

# ─── Chunking ─────────────────────────────────────────────────────────────────
# Long text is split into bounded chunks (characters) before synthesis so each
# provider stays within its safe input size (Kokoro's 510 phoneme-token cap,
# F5's ~30s/pass). See backend/app/core/chunker.py for the char-vs-token note.
KOKORO_CHUNK_CHARS=400
F5_CHUNK_CHARS=350
ELEVENLABS_CHUNK_CHARS=2400

# ─── Sleep stories ────────────────────────────────────────────────────────────
# Calming treatment applied ONLY to the sleep-story content type (never podcasts).
SLEEP_DEFAULT_SPEED=0.85          # slower narration (~90-110 WPM feel)
SLEEP_DEFAULT_PAUSE_MS=900        # silence inserted between sentences
SLEEP_SAMPLE_RATE=44100
SLEEP_CHANNELS=2                  # sleep masters are stereo
SLEEP_TARGET_LUFS=-20.0          # EBU R128 integrated loudness target
SLEEP_LOWPASS_HZ=8000            # gentle high-frequency roll-off
SLEEP_FADE_IN_S=2.0
SLEEP_FADE_OUT_S=5.0
AMBIENT_BED_GAIN_DB=-22.0        # how far under the narration an ambient bed sits
# Directory holding ambient beds (.wav/.mp3). Defaults to repo-root assets/ambient.
# AMBIENT_DIR=/absolute/path/to/assets/ambient

# ─── Voice catalog ────────────────────────────────────────────────────────────
# Optional JSON list of the voices offered in the UI dropdown. Each entry needs
# a voice "id"; "label" is optional (names are otherwise resolved from the API).
# Leave empty ([]) to offer every voice on your ElevenLabs account.
# Example:
# VOICE_CATALOG=[{"id":"21m00Tcm4TlvDq8ikWAM","label":"Rachel"},{"id":"AZnzlk1XvdvUeBnXmlld","label":"Domi"}]
VOICE_CATALOG=[]

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origins allowed to call the API (the Vite dev server by default).
CORS_ORIGINS=["http://localhost:5173"]
