# ─── Audio output ─────────────────────────────────────────────────────────────
# Format requested PER SEGMENT from the provider (codec_sampleRate_bitrate).
SEGMENT_OUTPUT_FORMAT=mp3_44100_128

# Final master export format: "m4a" (AAC-LC 256k, default) or "wav" (lossless).
FINAL_FORMAT=m4a

# Also export a lossless WAV backup alongside the primary format (true/false).
ALSO_EXPORT_WAV=true

# Silence inserted between speaker turns, in milliseconds.
INTER_TURN_GAP_MS=400

# Short edge fade (ms) on each chunk WAV to kill concat-boundary clicks. 0 = off.
CHUNK_EDGE_FADE_MS=8

# Directory (relative to the backend working dir) where episodes are written.
OUTPUT_DIR=output

# All segments are resampled to this rate before stitching, so providers with
# different native rates (Kokoro/F5 at 24kHz) mix cleanly.
TARGET_SAMPLE_RATE=44100

# ─── Local models (Kokoro, F5) ────────────────────────────────────────────────
# Directory holding F5 reference voices. Defaults to the repo-root assets/ dir.
# Layout: <ASSETS_DIR>/speakers/reference_audio/<name>.wav
#         <ASSETS_DIR>/speakers/reference_text/<name>.txt
# ASSETS_DIR=/absolute/path/to/assets

# Kokoro
KOKORO_SPEED=1.0

# F5. On Apple Silicon, float16-on-MPS garbles output and unsupported ops bounce
# to CPU — so the default runtime is CPU + float32 (reliable). F5_DEVICE=auto
# resolves to CUDA if present else CPU; set it to "mps" only if scripts/bench_f5.py
# shows MPS wins on your machine. NFE 16 (was 32) ~halves inference time.
F5_SPEED=1.0
F5_DEVICE=auto                  # auto | cpu | mps | cuda
F5_DTYPE=float32                # float32 | float16 (float16 only on CUDA)
F5_NFE_STEP=16
F5_CFG_STRENGTH=2.0
F5_SWAY_COEF=-1.0

# ─── Chunking ─────────────────────────────────────────────────────────────────
# Long text is split into bounded chunks (characters) before synthesis so each
# provider stays within its safe input size (Kokoro's 510 phoneme-token cap,
# F5's ~30s/pass). See backend/app/core/chunker.py for the char-vs-token note.
KOKORO_CHUNK_CHARS=400
F5_CHUNK_CHARS=250

# ─── Podcast pacing ───────────────────────────────────────────────────────────
# Conversational realism for podcasts (gated per-job by PodcastRequest.pacing,
# default on). Pacing + voice-emotion only — never loudness/EQ/fades (sleep-only).
PODCAST_DEFAULT_SPEED=1.0                # base speaking rate for local providers
PODCAST_SPEED_JITTER=0.03               # ± per-chunk speed variation (local only)
PODCAST_INTRA_SENTENCE_GAP_MS_MIN=80    # randomized micro-pause between sentences
PODCAST_INTRA_SENTENCE_GAP_MS_MAX=220
PODCAST_TURN_GAP_JITTER=0.4             # ± variation applied to INTER_TURN_GAP_MS

# ─── Sleep stories ────────────────────────────────────────────────────────────
# Calming treatment applied ONLY to the sleep-story content type (never podcasts).
SLEEP_DEFAULT_SPEED=0.85          # slower narration (~90-110 WPM feel)
SLEEP_DEFAULT_PAUSE_MS=900        # silence inserted between sentences
SLEEP_SAMPLE_RATE=44100
SLEEP_CHANNELS=2                  # sleep masters are stereo
# Progressive ramp-down (per story, toggled in the UI): how far speed eases and
# pauses lengthen by the end of the narration.
SLEEP_RAMP_SPEED_END_FACTOR=0.94 # final chunk speed = baseline × this
SLEEP_RAMP_PAUSE_SCALE=1.6       # final pauses = first × this
SLEEP_TARGET_LUFS=-18.0          # EBU R128 integrated loudness target
SLEEP_TRUE_PEAK_DB=-2.0          # loudnorm true-peak ceiling (dBTP)
SLEEP_LOWPASS_HZ=8000            # gentle high-frequency roll-off
SLEEP_FADE_IN_S=2.0
SLEEP_FADE_OUT_S=5.0
# Default duration (ms) for a bare [pause] tag with no explicit value.
SLEEP_PAUSE_DEFAULT_MS=1000
# Seconds of ambient-bed-only playback before the narration starts.
# Gives a gentle musical lead-in instead of an abrupt first word. 0 = disabled.
SLEEP_PREROLL_S=3.0
AMBIENT_BED_GAIN_DB=-22.0        # how far under the narration an ambient bed sits
# Directory holding ambient beds (.wav/.mp3). Defaults to repo-root assets/ambient.
# AMBIENT_DIR=/absolute/path/to/assets/ambient

# ─── Voice catalog ────────────────────────────────────────────────────────────
# Optional JSON list of the voices offered in the UI dropdown. Each entry needs
# a voice "id"; "label" is optional (names are otherwise resolved from the
# provider). Leave empty ([]) to offer every voice the provider reports.
# Example:
# VOICE_CATALOG=[{"id":"af_heart","label":"Heart (Kokoro)"}]
VOICE_CATALOG=[]

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origins allowed to call the API (the Vite dev server by default).
CORS_ORIGINS=["http://localhost:5173"]
